# ── MediBook frontend environment ──
# Copy this file to `.env` and fill in your values.
# Only PUBLIC/anon keys belong here — never the Supabase service-role key
# and never the Razorpay KEY_SECRET.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Razorpay publishable key id (safe in the browser). The KEY_SECRET is NOT set
# here — it is stored as a Supabase Edge Function secret (see README).
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxx

# Cloudflare Turnstile CAPTCHA — site key (public, browser-safe). Leave blank to
# disable captcha entirely. When set, also enable Captcha in the Supabase
# dashboard (Auth → Bot and Abuse Protection, provider "Turnstile") with the
# matching SECRET key. Both must be enabled together.
VITE_TURNSTILE_SITE_KEY=

# Abstract API email validation is used at registration to verify an email is
# real/deliverable. The API key is NOT a frontend var — it lives ONLY as a
# Supabase Edge Function secret (server-side), so it is never exposed:
#   supabase secrets set ABSTRACT_API_KEY=your_abstract_api_key
#   supabase functions deploy verify-email

# ── Edge Function CORS lock-down (server-side secret, NOT a frontend var) ──
# Restricts which browser origins may call the Supabase Edge Functions.
# Comma-separate multiple origins (production + preview + localhost) — the
# function echoes back whichever listed origin made the request. When unset,
# functions fall back to '*' so local development keeps working. Set this in
# production to close the wide-open CORS surface flagged in the assessment:
#   supabase secrets set ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
#   supabase functions deploy   # redeploy functions to pick up the new code + secret
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173
