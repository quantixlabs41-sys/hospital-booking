# ============================================================
# Environment Variables
# Create a .env file at the root and add these:
# ============================================================

# ── Supabase Configuration ──
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
VITE_SUPABASE_URL=https://llmqybsqarztoiisoyqx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxsbXF5YnNxYXJ6dG9paXNveXF4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODAxODQxNzEsImV4cCI6MjA5NTc2MDE3MX0.Fnp-5-Kg4OjwqKRHTuj8kRbiuTur3a4U5F8LZQkd0Bw


# ── Application Settings ──
# Hospital name displayed in header/footer
VITE_HOSPITAL_NAME="City Central Hospital"

# Default session duration in minutes (used for auto-expiration)
VITE_APPOINTMENT_SESSION_MINUTES=30

# ── Email Service Configuration (Supabase Email) ──
# Emails are sent via Supabase Auth SMTP (no external SMTP needed)
# Check: https://supabase.com/docs/guides/auth/auth-email-templates

# ── Optional: Email Templates ──
# You can customize email content in Supabase Dashboard -> Auth -> Email Templates
# Template names in dashboard: "Booking Confirmation", "Appointment Reminder", etc.

# ── Optional: Admin Defaults ──
# You can pre-set an admin email if needed (but we'll create one manually)
# VITE_ADMIN_EMAIL=your-admin-email@example.com
# VITE_ADMIN_PASSWORD=admin-password

# ── WhatsApp (OpenWA) Configuration ──
# Base URL of the OpenWA gateway REST API (Docker container)
# See docs/openwa-setup-guide.md for setup instructions
VITE_OPENWA_GATEWAY_URL=http://localhost:2785

# OpenWA API key (server-side only — used by Supabase Edge Functions)
# Generate with: openssl rand -hex 32
# IMPORTANT: Set this in Supabase Edge Function secrets, NOT as VITE_ prefix
OPENWA_API_KEY=medibook2025secure

# OpenWA session ID (must match docker-compose.openwa.yml)
OPENWA_SESSION_ID=medibook-hospital

# ── Security Configuration ──
# Session idle timeout in minutes (default: 30)
VITE_IDLE_TIMEOUT_MINUTES=30

